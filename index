<style>
  :root {
    --navy: #1F4E79;
    --ink: #1a3a5c;
    --gold: #F5B800;
    --gold-light: #ffd54f;
    --cream: #f0f6ff;
    --warm-white: #f7faff;
    --muted: #6b8cae;
    --border: #c8daf0;
    --tag-bg: #deeaf8;
    --link: #1F4E79;
    --link-hover: #0d3060;
    --red-accent: #c0392b;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'IBM Plex Sans', sans-serif;
    background: var(--warm-white);
    color: var(--ink);
    font-size: 14px;
    line-height: 1.6;
  }

  /* HEADER */
  .header {
    background: #1F4E79;
    color: #fff;
    padding: 40px 48px 32px;
    border-bottom: 3px solid var(--gold);
  }

  .header-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: #a8c4e0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .header h1 {
    font-size: 28px;
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .header h1 span {
    color: var(--gold);
  }

  .header-sub {
    font-size: 13px;
    color: #c5dcf0;
    font-weight: 300;
    font-style: italic;
    margin-bottom: 20px;
  }

  .header-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    padding: 3px 10px;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .badge-gold { background: var(--gold); color: var(--navy); font-weight: 600; }
  .badge-outline { border: 1px solid #4a7faa; color: #a8c4e0; }

  /* WHY NOW BANNER */
  .why-now {
    background: #eef5ff;
    border-left: 4px solid var(--gold);
    padding: 14px 48px;
    font-size: 13px;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
  }

  .why-now strong { color: #1F4E79; }

  /* MAIN LAYOUT */
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 48px 60px;
  }

  /* SECTION HEADERS */
  .section {
    margin-top: 36px;
  }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }

  /* DIVIDER */
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 28px 0;
  }

  /* RESOURCE GRID */
  .resource-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .resource-col {
    padding-right: 28px;
  }

  .resource-col:not(:last-child) {
    border-right: 1px solid var(--border);
    margin-right: 0;
  }

  .resource-col:not(:first-child) {
    padding-left: 28px;
    padding-right: 0;
  }

  .col-header {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 14px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--navy);
  }

  /* RESOURCE ITEMS */
  .resource-item {
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--tag-bg);
  }

  .resource-item:last-child {
    border-bottom: none;
  }

  .resource-name {
    font-weight: 600;
    font-size: 13px;
    color: var(--ink);
    margin-bottom: 1px;
  }

  .resource-name a {
    color: var(--link);
    text-decoration: none;
  }

  .resource-name a:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }

  .resource-handle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--link);
    margin-bottom: 3px;
    text-decoration: none;
    display: inline-block;
  }

  .resource-handle:hover { text-decoration: underline; color: var(--link-hover); }

  .resource-desc {
    font-size: 12px;
    color: #5a6a7a;
    line-height: 1.5;
    font-style: italic;
  }

  /* TAG */
  .tag {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 3px;
  }

  .tag-free { background: #e8f4e8; color: #2d6a2d; }
  .tag-paid { background: #f4e8e8; color: #6a2d2d; }
  .tag-new  { background: #e8eef8; color: #1a3a6a; }
  .tag-x    { background: #000; color: #fff; }
  .tag-li   { background: #0077b5; color: #fff; }

  /* STATS ROW */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 4px;
  }

  .stat-cell {
    background: var(--warm-white);
    padding: 14px 16px;
    text-align: center;
  }

  .stat-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 20px;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.1;
    display: block;
  }

  .stat-label {
    font-size: 10px;
    color: var(--muted);
    line-height: 1.3;
    margin-top: 3px;
  }

  /* LEVELS */
  .levels-list {
    list-style: none;
    counter-reset: level;
  }

  .level-item {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
    align-items: flex-start;
  }

  .level-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--gold);
    min-width: 18px;
    margin-top: 1px;
  }

  .level-content strong {
    font-size: 13px;
    color: var(--navy);
    display: block;
  }

  .level-content span {
    font-size: 12px;
    color: #5a6a7a;
    font-style: italic;
  }

  /* TWO COL */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  /* SKILLS LIST */
  .skill-row {
    display: flex;
    gap: 10px;
    margin-bottom: 11px;
    align-items: flex-start;
  }

  .skill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    margin-top: 6px;
    flex-shrink: 0;
  }

  .skill-text strong {
    font-size: 13px;
    color: var(--navy);
  }

  .skill-text span {
    font-size: 12px;
    color: #5a6a7a;
    display: block;
  }

  /* QUOTE BLOCK */
  .quote-block {
    background: #1F4E79;
    color: #fff;
    padding: 20px 24px;
    border-left: 4px solid var(--gold);
    margin-top: 24px;
  }

  .quote-text {
    font-size: 14px;
    font-style: italic;
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .quote-attr {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* FOOTER */
  .footer {
    background: #1F4E79;
    color: #a8c4e0;
    padding: 16px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.05em;
